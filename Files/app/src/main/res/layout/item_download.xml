<?xml version="1.0" encoding="utf-8"?>
<!--
 * item_download.xml
 * 下载列表单项布局：以 MaterialCardView 展示每个下载任务的
 * 标题、分辨率、进度条、状态文本和操作按钮。
 -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_border"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 第一行：标题 -->
        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/black" />

        <!-- 第二行：分辨率 + 文件大小 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_task_resolution"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_task_filesize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- 第三行：进度条（仅下载中和暂停中显示） -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <!-- 第四行：下载速度 + 已下载/总大小显示（仅下载中显示） -->
        <TextView
            android:id="@+id/tv_speed_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:visibility="gone" />

        <!-- 第五行：下载路径（可点击打开文件夹） -->
        <LinearLayout
            android:id="@+id/layout_download_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_path_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_download_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="@color/text_tertiary"
                android:maxLines="1"
                android:ellipsize="middle" />

            <!-- 打开按钮（带边框样式） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/tv_open_folder"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:minWidth="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/text_secondary"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:text="打开" />
        </LinearLayout>

        <!-- 第五行：状态 + 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 状态文本 -->
            <TextView
                android:id="@+id/tv_task_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary" />

            <!-- 取消按钮（带边框样式） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pause_resume"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:minWidth="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/status_error"
                android:textSize="13sp"
                android:textColor="@color/status_error"
                android:text="取消"
                android:visibility="gone" />

            <!-- 分享按钮（带边框样式，仅在任务已完成时由适配器控制显示） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:minWidth="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/text_secondary"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:text="分享"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <!-- 删除按钮（带边框样式） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:minWidth="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/status_error"
                android:textSize="13sp"
                android:textColor="@color/status_error"
                android:text="删除" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
