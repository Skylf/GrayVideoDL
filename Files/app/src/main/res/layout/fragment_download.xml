<?xml version="1.0" encoding="utf-8"?>
<!-- 下载列表 Fragment 布局：显示所有下载任务，含进度、状态 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ui.download.DownloadFragment">

    <!-- 页面标题 -->
    <TextView
        android:id="@+id/tv_page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="下载列表"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 下载列表 RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_download_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_page_title" />

    <!-- 空状态提示（无下载任务时显示） -->
    <TextView
        android:id="@+id/tv_empty_download"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:text="暂无下载任务"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_page_title" />

    <!-- FFmpeg 警告浮层：显示音视频合并失败警告 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_ffmpeg_warning_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:backgroundTint="@color/status_warning_bg"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_ffmpeg_warning_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ "
            android:textSize="16sp"
            android:textColor="@color/status_warning" />

        <TextView
            android:id="@+id/tv_ffmpeg_warning_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FFmpeg警告"
            android:textSize="14sp"
            android:textColor="@color/status_warning"
            android:gravity="center_vertical" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
