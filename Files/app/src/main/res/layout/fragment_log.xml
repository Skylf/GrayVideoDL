<?xml version="1.0" encoding="utf-8"?>
<!-- 独立日志页面：显示 yt-dlp 运行日志，带复制和清空按钮 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- 页面标题 -->
    <TextView
        android:id="@+id/tv_page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="运行日志"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 操作按钮行：复制 + 清空 -->
    <LinearLayout
        android:id="@+id/layout_log_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_page_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_log"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="复制日志"
            android:textSize="12sp"
            app:cornerRadius="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_log"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="清空日志"
            android:textSize="12sp"
            app:cornerRadius="6dp" />

    </LinearLayout>

    <!-- 日志内容区域 -->
    <ScrollView
        android:id="@+id/sv_log_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="?android:attr/colorBackgroundFloating"
        android:padding="12dp"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_log_actions">

        <TextView
            android:id="@+id/tv_log_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:text="等待操作..."
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurface"
            android:textIsSelectable="true"
            android:includeFontPadding="false" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
