<?xml version="1.0" encoding="utf-8"?>
<!--
首页 Fragment 布局（v2）：
顶部：URL 输入 + 操作按钮
中部：解析结果卡片（视频画质 / 音频 分栏显示）
底部：可折叠调试日志
浮层：成功提示动画
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- ========== 成功提示浮层（初始隐藏，解析成功后渐显） ========== -->
    <LinearLayout
        android:id="@+id/layout_success_toast"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/bg_success_toast"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_success_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="@color/success_green"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_success_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="解析成功"
            android:textSize="15sp"
            android:textColor="@color/success_green" />

    </LinearLayout>

    <!-- ========== 标题 ========== -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ========== 链接输入框 ========== -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_url_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="请输入或粘贴视频链接"
        app:endIconMode="clear_text"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_url_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:maxLines="2"
            android:importantForAutofill="no" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- ========== 自动合并音视频开关 ========== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_merge_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardElevation="0dp"
        app:contentPadding="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/input_url_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自动合并音视频"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_merge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ========== 操作按钮行 ========== -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/card_merge_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_parse"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="解析视频"
            android:textSize="14sp"
            app:icon="@drawable/ic_download"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_test_env"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="测试环境"
            android:textSize="14sp"
            app:icon="@drawable/ic_settings"
            app:iconSize="18dp" />

    </LinearLayout>

    <!-- ========== 画质警告横幅（默认隐藏，画质不满足时显示） ========== -->
    <LinearLayout
        android:id="@+id/layout_quality_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone"
        android:background="@drawable/bg_warning_banner"
        app:layout_constraintTop_toBottomOf="@id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_warning_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ "
            android:textSize="16sp"
            android:textColor="@color/warning_text" />

        <TextView
            android:id="@+id/tv_warning_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textSize="13sp"
            android:textColor="@color/warning_text"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- ========== 中部可滚动内容区 ========== -->
    <ScrollView
        android:id="@+id/sv_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_quality_warning">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== 解析结果卡片 ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardElevation="2dp"
                app:contentPadding="16dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 视频标题 -->
                    <TextView
                        android:id="@+id/tv_video_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <!-- 时长 + 格式统计 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_format_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- ===== 视频画质区域 ===== -->
                    <TextView
                        android:id="@+id/tv_video_section_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="视频画质"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <LinearLayout
                        android:id="@+id/layout_video_formats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <!-- ===== 音频区域（默认隐藏，不合并/仅下载音频时显示） ===== -->
                    <TextView
                        android:id="@+id/tv_audio_section_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="音频"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layout_audio_formats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <!-- 下载按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="请先选择画质"
                        android:textSize="14sp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_download"
                        app:iconSize="18dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 错误卡片 ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardElevation="2dp"
                app:contentPadding="16dp"
                app:strokeColor="@color/error_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="解析失败"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/error_text" />

                    <TextView
                        android:id="@+id/tv_error_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
